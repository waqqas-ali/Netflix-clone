{
  "expo": {
    "name": "Netflix-Clone",
    "slug": "Netflix-Clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/netflix-Splash.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#000",
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#000",
      "bundleIdentifier": "com.waqqasali.NetflixClone",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/netflix-Splash.png",
        "backgroundColor": "#000"
      },
      "package": "com.waqqasali.NetflixClone",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/netflix-Splash.png",
      "backgroundColor": "#000"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/netflix-Splash.png",
          "imageWidth": 3000,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
